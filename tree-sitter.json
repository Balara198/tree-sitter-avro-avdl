{
  "grammars": [
    {
      "name": "avro_avdl",
      "camelcase": "AvroAvdl",
      "scope": "source.avdl",
      "path": ".",
      "file-types": [
        "avdl"
      ],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "injection-regex": "^(avdl|avro_avdl)$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Avro AVDL grammar for tree-sitter",
    "authors": [
      {
        "name": "Victor Quiroz"
      },
      {
        "name": "Maintainers of tree-sitter-avro-avdl"
      }
    ],
    "links": {
      "repository": "https://github.com/YOUR_GITHUB_USER/tree-sitter-avro-avdl",
      "upstream": "https://github.com/victorhqc/tree-sitter-apache-avro"
    }
  },
  "bindings": {
    "c": true,
    "python": true
  }
}
